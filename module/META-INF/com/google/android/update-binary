#!/sbin/sh

SKIPUNZIP=1

OUTFD="$2"
ZIPFILE="$3"

[ -z "$MAGISK_VER_CODE" ] && MAGISK_VER_CODE=0

ui_print() { echo "ui_print $1" >> /proc/$$/fd/$OUTFD; }
abort()    { ui_print "ERROR: $1"; exit 1; }

cd /tmp
unzip -o "$ZIPFILE" customize.sh -d /tmp/exfat-install >&2
chmod +x /tmp/exfat-install/customize.sh

MODPATH=/data/adb/modules_update/exfat-fuse-support
mkdir -p "$MODPATH"

export MODPATH ZIPFILE
. /tmp/exfat-install/customize.sh

rm -rf /tmp/exfat-install
